{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ExampleAnalyzer",
          "version": "1.0.0",
          "informationUri": "https://example.com/analyzer",
          "rules": [
            {
              "id": "EX0001",
              "name": "ExampleRule",
              "shortDescription": { "text": "An example rule." },
              "defaultConfiguration": { "level": "warning" },
              "helpUri": "https://example.com/rules/EX0001"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "EX0001",
          "ruleIndex": 0,
          "level": "warning",
          "message": { "text": "An example finding." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/example.cs" },
                "region": {
                  "startLine": 10,
                  "startColumn": 5,
                  "endLine": 10,
                  "endColumn": 25,
                  "snippet": { "text": "var x = null;" }
                }
              }
            }
          ],
          "properties": {
            "tags": [ "example", "demo" ]
          }
        }
      ]
    }
  ]
}
